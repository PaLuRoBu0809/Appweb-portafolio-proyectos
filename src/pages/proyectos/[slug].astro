---
import MainLayout from '../../layouts/MainLayout.astro';
import { sanityClient } from '../../lib/sanity';

interface Descarga {
  nombre: string;
  sub: string;
  link: string;
}

interface Proyecto {
  slug: string;
  title: string;
  subtitle: string;
  bannerImage: string;
  description: string;
  queHace: string[];
  stack: string[];
  highlights: string[];
  meta: { estado: string; tipo: string; documentacion: string };
  descargas: Descarga[];
}

const { slug } = Astro.params;

const proyecto = await sanityClient.fetch<Proyecto>(
  `*[_type == "project" && slug.current == $slug][0] {
    "slug": slug.current,
    title,
    subtitle,
    "bannerImage": bannerImage.asset->url,
    description,
    queHace,
    stack,
    highlights,
    meta,
    "descargas": descargas[] {
      nombre,
      sub,
      "link": archivo.asset->url
    }
  }`,
  { slug }
);

if (!proyecto) return Astro.redirect('/mis-proyectos');
---
<MainLayout title={`${proyecto.title} | Pablo Rodríguez`}>
  
  <div class="relative w-full h-64 md:h-80 rounded-2xl overflow-hidden mb-10 bg-zinc-900 border border-gray-900">
    <img 
      src={proyecto.bannerImage} 
      alt={proyecto.title} 
      class="w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
    
    <div class="absolute bottom-6 left-6 md:left-10 right-6">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight mb-2">
        {proyecto.title}
      </h1>
      <p class="text-gray-300 text-sm md:text-lg font-medium">
        {proyecto.subtitle}
      </p>
    </div>
  </div>

  <div class="max-w-3xl space-y-8 pb-20">
    
    <p class="text-gray-300 text-base leading-relaxed">
      {proyecto.description}
    </p>

    <div class="space-y-3">
      <h2 class="text-lg font-bold text-white tracking-wide">¿Qué hace?</h2>
      <ul class="list-disc list-inside space-y-2 text-gray-400 text-sm leading-relaxed">
        {proyecto.queHace.map((item) => (
          <li><span class="text-gray-300">{item}</span></li>
        ))}
      </ul>
    </div>

    <div class="space-y-3">
      <h2 class="text-lg font-bold text-white tracking-wide">Stack tecnológico</h2>
      <p class="text-gray-400 text-sm tracking-wide leading-relaxed">
        {proyecto.stack.join(' | ')}
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-lg font-bold text-white tracking-wide">Highlights técnicos</h2>
      <ul class="list-disc list-inside space-y-2 text-gray-400 text-sm leading-relaxed">
        {proyecto.highlights.map((highlight) => (
          <li><span class="text-gray-300">{highlight}</span></li>
        ))}
      </ul>
    </div>

    <div class="pt-4 border-t border-gray-900 text-xs md:text-sm text-gray-400 flex flex-wrap gap-x-4 gap-y-2 font-medium">
      <div>Estado: <span class="text-white"> {proyecto.meta.estado}</span></div>
      <div class="text-gray-800">|</div>
      <div>Tipo: <span class="text-white">{proyecto.meta.tipo}</span></div>
      <div class="text-gray-800">|</div>
      <div>Documentación: <span class="text-white">{proyecto.meta.documentacion}</span></div>
    </div>

    <div class="space-y-3 pt-4">
      {proyecto.descargas.map((archivo) => (
        <div class="flex justify-between items-center border border-gray-900 rounded-xl p-4 bg-zinc-950/40 hover:bg-zinc-950/80 transition-colors">
          <div class="flex items-center gap-4">
            <div class="p-2.5 bg-zinc-900 rounded-lg text-blue-400 border border-gray-800">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-white">{archivo.nombre}</h3>
              <p class="text-xs text-gray-500">{archivo.sub}</p>
            </div>
          </div>
          
          <a href={archivo.link} download target="_blank" rel="noopener noreferrer" class="bg-white text-black font-semibold text-xs px-4 py-2 rounded hover:bg-gray-200 transition-colors active:scale-95">
            Descargar
          </a>
        </div>
      ))}
    </div>

  </div>
</MainLayout>