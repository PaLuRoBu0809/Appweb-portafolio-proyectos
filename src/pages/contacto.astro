---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contactame">
  
  <div class="py-12 md:py-20 max-w-2xl">
    
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-10 tracking-tight">
      ¡Contáctame y hablemos!
    </h1>

    <form id="contact-form" class="space-y-6">
      
      <div>
        <label for="nombre" class="block text-sm text-gray-400 mb-2">
          Nombre completo
        </label>
        <input 
          type="text" 
          id="nombre" 
          name="nombre" 
          required
          placeholder="Ingrese su nombre completo" 
          class="w-full bg-transparent border border-zinc-700 focus:border-white focus:ring-1 focus:ring-white rounded-lg px-4 py-3 text-white placeholder-zinc-600 outline-none transition-all duration-200"
        />
      </div>

      <div>
        <label for="email" class="block text-sm text-gray-400 mb-2">
          Correo electronico
        </label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required
          placeholder="Ingrese su correo electronico" 
          class="w-full bg-transparent border border-zinc-700 focus:border-white focus:ring-1 focus:ring-white rounded-lg px-4 py-3 text-white placeholder-zinc-600 outline-none transition-all duration-200"
        />
      </div>

      <div>
        <label for="telefono" class="block text-sm text-gray-400 mb-2">
          Telefono
        </label>
        <input 
          type="tel" 
          id="telefono" 
          name="telefono" 
          placeholder="Ingrese su telefono" 
          class="w-full bg-transparent border border-zinc-700 focus:border-white focus:ring-1 focus:ring-white rounded-lg px-4 py-3 text-white placeholder-zinc-600 outline-none transition-all duration-200"
        />
      </div>

      <div>
        <label for="mensaje" class="block text-sm text-gray-400 mb-2">
          Mensaje
        </label>
        <textarea 
          id="mensaje" 
          name="mensaje" 
          rows="5" 
          required
          placeholder="Ingresa un mensaje" 
          class="w-full bg-transparent border border-zinc-700 focus:border-white focus:ring-1 focus:ring-white rounded-lg px-4 py-3 text-white placeholder-zinc-600 outline-none transition-all duration-200 resize-none"
        ></textarea>
      </div>

      <div class="pt-2">
        <button 
          type="submit" 
          class="bg-white text-black font-semibold px-10 py-3 rounded hover:bg-gray-200 active:scale-95 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Enviar
        </button>
      </div>

    </form>

  </div>

<div 
    id="toast" 
    class="fixed bottom-5 right-5 px-6 py-3 rounded-lg font-medium opacity-0 pointer-events-none transform translate-y-5 transition-all duration-300 shadow-2xl z-[9999] bg-zinc-900 border border-zinc-700 text-white flex items-center gap-3"
  >
    <span id="toast-icon" class="text-lg"></span>
    <span id="toast-message"></span>
  </div>

  <script>
  import "../Scripts/contactForm.ts";
  </script>

</MainLayout>


</MainLayout>