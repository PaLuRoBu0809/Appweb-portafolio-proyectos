---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from '../lib/sanity';

const proyectos = await sanityClient.fetch(`*[_type == "project"] | order(_createdAt desc) {
  "slug": slug.current,
  title,
  subtitle,
  "bannerImage": bannerImage.asset->url,
  description,
  stack
}`);
---

<MainLayout title="Mis Proyectos">
  
  <div class="py-12 md:py-20">
    
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-12 flex items-baseline gap-3">
      Mis proyectos 
      <span class="text-gray-600 text-2xl font-medium">({proyectos?.length || 0})</span>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      {proyectos && proyectos.map(({ title = "Proyecto sin título", description = "", stack = [], slug = "#", bannerImage = "" }) => (
        <div class="border border-gray-900 rounded-xl bg-zinc-950/30 hover:border-gray-800 hover:bg-zinc-950/60 transition-all duration-300 group flex flex-col overflow-hidden">
          
          <div class="relative w-full h-48 md:h-56 overflow-hidden bg-zinc-900 border-b border-gray-900/60">
            {bannerImage && (
              <img 
                src={bannerImage} 
                alt={`Miniatura de ${title}`} 
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-300"
              />
            )}
            
            <a href={`/proyectos/${slug}`} class="absolute top-3 right-3 text-gray-400 hover:text-white transition-colors p-2 bg-zinc-950/60 rounded-full" aria-label="Ver detalles del proyecto">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                </svg>
            </a>
          </div>
          
          <div class="p-6 flex-grow flex flex-col justify-between">
            <div>
                <a href={`/proyectos/${slug}`} class="hover:underline decoration-gray-500">
                  <h2 class="text-xl font-bold text-white mb-3 tracking-tight">
                      {title}
                  </h2>
                </a>
                
                <p class="text-gray-400 text-sm leading-relaxed mb-6">
                    {description}
                </p>
            </div>

            <div class="flex flex-wrap gap-2 pt-4 border-t border-gray-900/60">
                {stack.map((stack) => (
                    <span class="text-xs bg-zinc-900/80 text-gray-400 border border-gray-800/80 px-2.5 py-1 rounded-md font-medium tracking-wide">
                        {stack}
                    </span>
                ))}
            </div>
          </div>

        </div>
      ))}

    </div>

  </div>

</MainLayout>