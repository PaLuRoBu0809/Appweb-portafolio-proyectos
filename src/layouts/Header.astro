---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full z-50 bg-black px-6 md:px-12 lg:px-18 flex justify-between items-center py-6 border-b border-gray-900">
  <a href="/" class="text-xl font-extrabold tracking-wider text-white">
    PABLO RODRIGUEZ
  </a>
  
  <nav class="hidden md:flex gap-4 md:gap-8 text-sm font-medium items-center">
    <a 
      href="/quien-soy" 
      class={`transition-all duration-300 ease-in-out active:scale-95 px-3 py-1 rounded ${currentPath.endsWith('/quien-soy') || currentPath.endsWith('/quien-soy/') ? 'bg-white text-black font-bold' : 'text-gray-400 hover:text-white'}`}
    >
      ¿Quien soy?
    </a>
      
    <a 
      href="/mis-proyectos" 
      class={`transition-all duration-300 ease-in-out active:scale-95 px-3 py-1 rounded ${currentPath.endsWith('/mis-proyectos') || currentPath.endsWith('/mis-proyectos/') ? 'bg-white text-black font-bold' : 'text-gray-400 hover:text-white'}`}
    >
      Mis proyectos
    </a>
      
    <a 
      href="/contacto" 
      class={`transition-all duration-300 ease-in-out active:scale-95 px-3 py-1 rounded ${currentPath.endsWith('/contacto') || currentPath.endsWith('/contacto/') ? 'bg-white text-black font-bold' : 'text-gray-400 hover:text-white'}`}
    >
      Contacto
    </a>
  </nav>

  <nav class="flex md:hidden gap-2 items-center">
    <a 
      href="/quien-soy" 
      class={`p-2 rounded-lg transition-all ease-in-out active:scale-95 ${currentPath.endsWith('/quien-soy') || currentPath.endsWith('/quien-soy/') ? 'bg-white text-black' : 'bg-gray-900 text-gray-400 hover:text-white'}`}
      aria-label="¿Quien soy?"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
    </a>
    <a 
      href="/mis-proyectos" 
      class={`p-2 rounded-lg transition-all ease-in-out active:scale-95 ${currentPath.endsWith('/mis-proyectos') || currentPath.endsWith('/mis-proyectos/') ? 'bg-white text-black' : 'bg-gray-900 text-gray-400 hover:text-white'}`}
      aria-label="Mis proyectos"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.08-.896 1.96-2.006 1.96H5.756c-1.11 0-2.006-.88-2.006-1.96v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.896-1.96-2.006-1.96H5.756c-1.11 0-2.006.88-2.006 1.96v3.783c0 .713.27 1.396.75 1.661m16.5 0l-8.25 5.25-8.25-5.25m16.5 0V8.25m-16.5 0v5.9" /></svg>
    </a>
    <a 
      href="/contacto" 
      class={`p-2 rounded-lg transition-all ease-in-out active:scale-95 ${currentPath.endsWith('/contacto') || currentPath.endsWith('/contacto/') ? 'bg-white text-black' : 'bg-gray-900 text-gray-400 hover:text-white'}`}
      aria-label="Contacto"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
    </a>
  </nav>
</header>