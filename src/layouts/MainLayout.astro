---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white font-sans antialiased selection:bg-white selection:text-black min-h-screen flex flex-col">
    
    <div class="w-full px-6 md:px-12 lg:px-18 flex-grow flex flex-col pt-32 pb-44">
      
      <header class="fixed top-0 left-0 w-full z-50 bg-black px-6 md:px-12 lg:px-18 flex justify-between items-center py-6 border-b border-gray-900">
        <a href="/" class="text-xl font-extrabold tracking-wider">
          PABLO RODRIGUEZ
        </a>
        
        <nav class="flex gap-4 md:gap-8 text-sm font-medium items-center">
          <a 
            href="/quien-soy" 
            class={`transition-all duration-300 ease-in-out active:scale-95 px-3 py-1 rounded ${currentPath.endsWith('/quien-soy') || currentPath.endsWith('/quien-soy/') ? 'bg-white text-black font-bold' : 'text-gray-400 hover:text-white'}`}
          >
            ¿Quien soy?
          </a>
            
          <a 
            href="/mis-proyectos" 
            class={`transition-all duration-300 ease-in-out active:scale-95 px-3 py-1 rounded ${currentPath.endsWith('/mis-proyectos') || currentPath.endsWith('/mis-proyectos/') ? 'bg-white text-black font-bold' : 'text-gray-400 hover:text-white'}`}
          >
            Mis proyectos
            </a>
            
          <a 
            href="/contacto" 
            class={`transition-all duration-300 ease-in-out active:scale-95 px-3 py-1 rounded ${currentPath.endsWith('/contacto') || currentPath.endsWith('/contacto/') ? 'bg-white text-black font-bold' : 'text-gray-400 hover:text-white'}`}
           >
            Contacto
        </a>
      </nav>
      </header>

      <main class="flex-grow">
        <slot />
      </main>

      <footer class="fixed bottom-0 left-0 w-full z-50 bg-black px-6 md:px-12 lg:px-18 py-6 border-t border-gray-900">
    <p class="text-sm text-gray-400 mb-4">Mas sobre mi:</p>
    <div class="flex gap-4">
        
        <a href="https://www.instagram.com/palurobu0809?igsh=MWI1dzl0MHkwZTNrdg==" class="text-white hover:text-gray-400 transition-colors" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
        </svg>
        </a>

        <a href="https://www.linkedin.com/in/pablo-luis-rodriguez-burgos-0989a9357?utm_source=share_via&utm_content=profile&utm_medium=member_android" class="text-white hover:text-gray-400 transition-colors" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
        </svg>
        </a>

        <a href="https://github.com/PaLuRoBu0809" class="text-white hover:text-gray-400 transition-colors" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
        </a>

    </div>
    </footer>

    </div>
  </body>
</html>