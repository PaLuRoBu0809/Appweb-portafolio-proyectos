---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro'; // <--- Importamos tu nuevo componente de Footer

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white font-sans antialiased selection:bg-white selection:text-black min-h-screen flex flex-col">
    
    <div class="w-full px-6 md:px-12 lg:px-18 flex-grow flex flex-col pt-32 pb-44">
      
      <Header />

      <main class="flex-grow">
        <slot />
      </main>

      <Footer />

    </div>
  </body>
</html>